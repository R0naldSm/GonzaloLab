# ============================================
# CONFIGURACIÓN GONZALOLABS
# ============================================

# Base de Datos
DB_HOST=localhost
DB_NAME=gonzalolabs_db
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Aplicación
APP_NAME=GonzaloLabs
APP_URL=http://localhost/gonzalolabs
APP_ENV=development
APP_DEBUG=true

# Seguridad
SESSION_LIFETIME=1800
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=1800
REQUIRE_HTTPS=false

# Email (para recuperación de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=stevenmotaronald@gmail.com
SMTP_PASSWORD=tu_password_app
SMTP_FROM=noreply@gonzalolabs.com
SMTP_FROM_NAME=GonzaloLabs

# Tiempo de expiración de resultados
EXPIRACION_RAPIDA_MIN=120
EXPIRACION_ESTANDAR_DIAS=30

# Rutas
UPLOAD_PATH=/uploads
LOG_PATH=/storage/logs